# ── App ────────────────────────────────────────────────
APP_NAME=AgentVerse
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string
API_V1_PREFIX=/api/v1

# ── LLM Providers ──────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEFAULT_MODEL_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-6

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentverse
POSTGRES_USER=agentverse
POSTGRES_PASSWORD=agentverse
DATABASE_URL=postgresql+asyncpg://agentverse:agentverse@localhost:5432/agentverse

# ── Redis ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ── Vector DB (Qdrant) ─────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=agentverse_memory

# ── Web search tool ────────────────────────────────────
TAVILY_API_KEY=

# ── Auth ───────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Agent limits ───────────────────────────────────────
MAX_RETRIES=2
MAX_PLAN_STEPS=10
CRITIC_PASS_THRESHOLD=0.75

# ── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
